### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down n
set $up e
set $right i

set $black        #282828
set $darkred      #cc241d
set $darkgreen    #98971a
set $darkyellow   #d79921
set $darkblue     #458588
set $darkmagenta  #b16286
set $darkcyan     #689d6a
set $lightgray    #a89984
set $darkgray     #928374
set $red          #fb4934
set $green        #b8bb26
set $yellow       #fabd2f
set $blue         #83a598
set $magenta      #d3869b
set $cyan         #8ec07c
set $white        #ebdbb2

set $term foot
set $menu rofi -show drun
set $browser brave --enable-features=UseOzonePlatform --ozone-platform=wayland
set $filemanager thunar
set $editor /usr/bin/emacsclient -c -a=
set $launcher ~/.config/rofi/scripts/launcher_t6
set $exit $launcher
